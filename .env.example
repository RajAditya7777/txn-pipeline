# ==========================================
# Application Configuration
# ==========================================

# Required: Name of the application
PROJECT_NAME="AI Transaction Processing Pipeline"

# Optional: Deployment environment (development, staging, production)
ENVIRONMENT="development"

# Optional: Enable debug mode for verbose output
DEBUG=True

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Required: Cryptographic secret key for the application
SECRET_KEY="your-super-secret-key-change-in-production"

# ==========================================
# PostgreSQL Database Configuration
# ==========================================

# Local Development Settings
# These values assume you are running the app locally connecting to a local DB.
# NOTE: Docker Compose automatically overrides POSTGRES_SERVER to "db" via the environment block.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_password"
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="txn_pipeline"

# ==========================================
# Redis Configuration
# ==========================================

# Local Development Settings
# NOTE: Docker Compose automatically overrides REDIS_URL to "redis://redis:6379/0".
REDIS_URL="redis://localhost:6379/0"

# ==========================================
# LLM Integration (Google Gemini)
# ==========================================

# Required: Your Google Gemini API Key
# You must provide this to enable categorization and summary features.
GEMINI_API_KEY="your_gemini_api_key_here"
